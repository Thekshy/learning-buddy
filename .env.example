# =====================================================
# Learning Buddy — 环境变量样例
# 复制本文件为 .env 并填入真实值。.env 已在 .gitignore
# =====================================================

# ---------- 应用 ----------
APP_NAME=learning-buddy
APP_ENV=dev                # dev | test | prod
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_ORIGIN=http://localhost:3000

# ---------- 安全 / 鉴权 ----------
# 生产请用 32 字节以上随机串;这里给个示例,真上线前重置
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_TTL_HOURS=72
BCRYPT_ROUNDS=10

# ---------- LLM: MiniMax M3 ----------
# Spring AI OpenAI 客户端硬编码 /v1/chat/completions 路径(OpenAI 标准)
# Ark Coding 端点实际是 /api/coding/v3/chat/completions,但 Ark 同时兼容 /v1/ 路径
# 所以 base URL 设为 /api/coding(不含 /v3),让 Spring AI 拼出 /api/coding/v1/chat/completions
# 错误示范:LLM_BASE_URL=.../v3  → Spring AI 拼出 .../v3/v1/chat/completions 多一段 /v3
LLM_PROVIDER=minimax
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=minimax-m3
LLM_EMBED_MODEL=minimax-embedding-01
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60
# LLM 不可用时降级到 mock 响应(便于离线演示)
LLM_FALLBACK_MOCK=true

# ---------- 向量库:zvec ----------
ZVEC_DATA_DIR=./data/zvec
ZVEC_COLLECTION_DEFAULT=learning_buddy_default
ZVEC_DIM=1024
ZVEC_TOPK=5

# ---------- 关系库(本仓库默认 H2 文件库,首次跑自动建表) ----------
DB_URL=jdbc:h2:file:./data/learning-buddy;AUTO_SERVER=TRUE;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
# 切换 MySQL:DB_URL=jdbc:mysql://localhost:3306/learning_buddy?useSSL=false&serverTimezone=UTC
# 切换 PostgreSQL:DB_URL=jdbc:postgresql://localhost:5432/learning_buddy

# ---------- RAG ----------
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=80
RAG_MAX_UPLOAD_MB=20

# ---------- 日志 ----------
LOG_LEVEL=INFO
